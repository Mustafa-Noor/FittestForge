<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:id="@+id/dayContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_secondary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Day number badge -->
        <FrameLayout
            android:id="@+id/dayBadge"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_bottom_sheet"
            android:backgroundTint="@color/bg_tertiary">

            <TextView
                android:id="@+id/tvDayNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="1"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Day info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tvDayFocus"
                style="@style/TextStyle.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Core Activation"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDayDesc"
                style="@style/TextStyle.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Plank, crunch, leg raise..."
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- Status icon -->
        <TextView
            android:id="@+id/tvDayStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒"
            android:textSize="20sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
