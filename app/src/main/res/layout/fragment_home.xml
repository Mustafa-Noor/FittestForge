<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:fitsSystemWindows="true">

        <!-- A. Top Bar -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivProfile"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MaterialComponents.Indicator.Circle"
            tools:src="@drawable/ic_person" />

        <TextView
            android:id="@+id/tvGreeting"
            style="@style/TextStyle.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Good morning, Muhammad 👋"
            app:layout_constraintBottom_toTopOf="@id/tvDate"
            app:layout_constraintStart_toEndOf="@id/ivProfile"
            app:layout_constraintTop_toTopOf="@id/ivProfile"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/tvDate"
            style="@style/TextStyle.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sunday, 1 June"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@id/ivProfile"
            app:layout_constraintStart_toStartOf="@id/tvGreeting"
            app:layout_constraintTop_toBottomOf="@id/tvGreeting" />

        <LinearLayout
            android:id="@+id/layoutStreakTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bottom_sheet"
            android:backgroundTint="@color/bg_secondary"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="@id/ivProfile"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/ivProfile">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 "
                android:textSize="16sp" />
            <TextView
                android:id="@+id/tvTopStreak"
                style="@style/TextStyle.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/primary"
                android:textSize="16sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivCalendar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_check"
            app:tint="@color/primary"
            android:padding="6dp"
            android:background="@drawable/bg_bottom_sheet"
            android:backgroundTint="@color/bg_secondary"
            app:layout_constraintBottom_toBottomOf="@id/ivProfile"
            app:layout_constraintEnd_toStartOf="@id/layoutStreakTop"
            app:layout_constraintTop_toTopOf="@id/ivProfile" />

        <!-- B. Momentum Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMomentum"
            style="@style/Card.Default"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/ivProfile">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvMomentumTitle"
                    style="@style/TextStyle.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YOUR MOMENTUM"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.mikhaellopez.circularprogressbar.CircularProgressBar
                    android:id="@+id/momentumProgressBar"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_marginTop="20dp"
                    app:cpb_background_progressbar_color="@color/bg_tertiary"
                    app:cpb_background_progressbar_width="10dp"
                    app:cpb_progressbar_color="@color/primary"
                    app:cpb_progressbar_width="12dp"
                    app:cpb_round_border="true"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvMomentumTitle" />

                <TextView
                    android:id="@+id/tvMomentumValue"
                    style="@style/TextStyle.Display"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="78%"
                    app:layout_constraintBottom_toBottomOf="@id/momentumProgressBar"
                    app:layout_constraintEnd_toEndOf="@id/momentumProgressBar"
                    app:layout_constraintStart_toStartOf="@id/momentumProgressBar"
                    app:layout_constraintTop_toTopOf="@id/momentumProgressBar" />

                <TextView
                    android:id="@+id/tvMomentumLabel"
                    style="@style/TextStyle.Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Strong Momentum"
                    android:textColor="@color/primary"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/momentumProgressBar" />

                <View
                    android:id="@+id/momentumTrack"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_bottom_sheet"
                    android:backgroundTint="@color/bg_tertiary"
                    app:layout_constraintTop_toBottomOf="@id/tvMomentumLabel" />

                <View
                    android:id="@+id/momentumFill"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_bottom_sheet"
                    android:backgroundTint="@color/primary"
                    app:layout_constraintBottom_toBottomOf="@id/momentumTrack"
                    app:layout_constraintStart_toStartOf="@id/momentumTrack"
                    app:layout_constraintTop_toTopOf="@id/momentumTrack"
                    app:layout_constraintWidth_percent="0.78" />

                <TextView
                    android:id="@+id/tvMomentumMessage"
                    style="@style/TextStyle.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="LET'S GOOO! You're absolutely BUILT DIFFERENT right now! 🔥"
                    android:textAlignment="center"
                    android:textStyle="italic"
                    app:layout_constraintTop_toBottomOf="@id/momentumTrack" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- C. Quick Stats Row -->
        <LinearLayout
            android:id="@+id/layoutStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/cardMomentum">

            <com.google.android.material.card.MaterialCardView
                style="@style/Card.Default"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/tvStatStreak"
                        style="@style/TextStyle.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/primary"
                        android:textSize="20sp" />
                    <TextView
                        style="@style/TextStyle.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Streak" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Card.Default"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/tvStatWorkouts"
                        style="@style/TextStyle.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/primary"
                        android:textSize="20sp" />
                    <TextView
                        style="@style/TextStyle.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Workouts" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Card.Default"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/tvStatHours"
                        style="@style/TextStyle.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0h"
                        android:textColor="@color/primary"
                        android:textSize="20sp" />
                    <TextView
                        style="@style/TextStyle.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="This week" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- D. Today's Plan -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTodayPlan"
            style="@style/Card.Default"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/primary"
            app:layout_constraintTop_toBottomOf="@id/layoutStats">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">
                <TextView
                    android:id="@+id/tvPlanTitle"
                    style="@style/TextStyle.Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready to move?"
                    android:textColor="@color/white"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <TextView
                    android:id="@+id/tvPlanMessage"
                    style="@style/TextStyle.Body"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Your couch is starting to recognize your body shape 💀"
                    android:textColor="@color/white"
                    android:textStyle="italic"
                    app:layout_constraintEnd_toStartOf="@id/btnStartWorkoutHome"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvPlanTitle" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStartWorkoutHome"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/white"
                    android:text="START"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    app:cornerRadius="8dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- E. Recent Activity -->
        <TextView
            android:id="@+id/tvRecentTitle"
            style="@style/TextStyle.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Recent Workouts"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardTodayPlan" />

        <TextView
            android:id="@+id/btnViewAll"
            style="@style/TextStyle.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="View All →"
            android:textColor="@color/primary"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tvRecentTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvRecentTitle" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRecentWorkouts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/tvRecentTitle"
            tools:itemCount="3"
            tools:listitem="@layout/item_workout_history" />

        <!-- F. Daily Tip -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDailyTip"
            style="@style/Card.Default"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rvRecentWorkouts">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    style="@style/TextStyle.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COACH SAYS:"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvDailyTip"
                    style="@style/TextStyle.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Recovery is part of the process. If you're feeling sore, focus on mobility today." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
